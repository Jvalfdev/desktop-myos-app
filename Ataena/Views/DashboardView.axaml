<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ataena.ViewModels"
             xmlns:models="using:Ataena.Models"
             x:Class="Ataena.Views.DashboardView"
             x:DataType="vm:DashboardViewModel"
             Loaded="OnLoaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,32" Spacing="24">

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- CABECERA                                            -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="0">

                    <!-- Línea de acento con degradado -->
                    <Border Height="3" Width="52" CornerRadius="2"
                            HorizontalAlignment="Left" Margin="0,0,0,14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#a855f7" Offset="0"/>
                                <GradientStop Color="#f97316" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <TextBlock Text="{Binding Saludo}"
                               FontSize="34" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding NombreEstudio}"
                               FontSize="14" Foreground="#475569" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Pill de fecha con borde degradado -->
                <Border Grid.Column="1" VerticalAlignment="Top"
                        CornerRadius="20" Padding="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#a855f7" Offset="0"/>
                            <GradientStop Color="#f97316" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border CornerRadius="19" Padding="16,8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#130c22" Offset="0"/>
                                <GradientStop Color="#1c1008" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="{Binding FechaHoy}"
                                   FontSize="12" Foreground="#94a3b8"/>
                    </Border>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ACCIONES RÁPIDAS                                    -->
            <!-- ═══════════════════════════════════════════════════ -->
            <StackPanel Orientation="Horizontal" Spacing="10"
                        IsVisible="{Binding MostrarAccionesRapidas}">

                <!-- Nuevo cliente -->
                <Button Classes="quick-action" Padding="16,11" CornerRadius="12"
                        Command="{Binding NuevoClienteRapidoCommand}">
                    <Button.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#a855f7" Offset="0"/>
                            <GradientStop Color="#6366f1" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.BorderBrush>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="28" Height="28" CornerRadius="8" Background="#a855f725">
                            <TextBlock Text="👤" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Nuevo cliente" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#e2e8f0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Nueva cita -->
                <Button Classes="quick-action" Padding="16,11" CornerRadius="12"
                        Command="{Binding NuevaCitaRapidaCommand}">
                    <Button.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#10b981" Offset="0"/>
                            <GradientStop Color="#06b6d4" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.BorderBrush>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="28" Height="28" CornerRadius="8" Background="#10b98125">
                            <TextBlock Text="📅" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Nueva cita" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#e2e8f0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Nuevo trabajo -->
                <Button Classes="quick-action" Padding="16,11" CornerRadius="12"
                        Command="{Binding NuevoTrabajoRapidoCommand}">
                    <Button.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#f97316" Offset="0"/>
                            <GradientStop Color="#f59e0b" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.BorderBrush>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="28" Height="28" CornerRadius="8" Background="#f9731625">
                            <TextBlock Text="🎨" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Nuevo trabajo" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#e2e8f0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- TARJETAS DE ESTADÍSTICAS                            -->
            <!-- ═══════════════════════════════════════════════════ -->
            <StackPanel Orientation="Horizontal" Spacing="14"
                        IsVisible="{Binding MostrarEstadisticas}">

                <!-- ── Clientes activos ── -->
                <Border CornerRadius="16" Padding="1" MinWidth="190">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#a855f7" Offset="0"/>
                            <GradientStop Color="#6366f1" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border CornerRadius="15" Padding="22,20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                <GradientStop Color="#0d0a1f" Offset="0"/>
                                <GradientStop Color="#0a0d1f" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Spacing="14">
                            <Border Width="42" Height="42" CornerRadius="12" HorizontalAlignment="Left">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#a855f735" Offset="0"/>
                                        <GradientStop Color="#6366f125" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="👥" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding TotalClientes}"
                                       FontSize="46" FontWeight="Bold" Foreground="#a855f7"/>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Clientes activos"
                                           FontSize="13" Foreground="#94a3b8" FontWeight="Medium"/>
                                <TextBlock Text="en el sistema"
                                           FontSize="11" Foreground="#334155"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- ── Citas hoy ── -->
                <Border CornerRadius="16" Padding="1" MinWidth="190">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#10b981" Offset="0"/>
                            <GradientStop Color="#06b6d4" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border CornerRadius="15" Padding="22,20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                <GradientStop Color="#081a14" Offset="0"/>
                                <GradientStop Color="#081820" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Spacing="14">
                            <Border Width="42" Height="42" CornerRadius="12" HorizontalAlignment="Left">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#10b98135" Offset="0"/>
                                        <GradientStop Color="#06b6d425" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="📅" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding CitasHoyCount}"
                                       FontSize="46" FontWeight="Bold" Foreground="#10b981"/>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Citas de hoy"
                                           FontSize="13" Foreground="#94a3b8" FontWeight="Medium"/>
                                <TextBlock Text="programadas"
                                           FontSize="11" Foreground="#334155"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- ── Por confirmar ── -->
                <Border CornerRadius="16" Padding="1" MinWidth="190">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#f97316" Offset="0"/>
                            <GradientStop Color="#ef4444" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border CornerRadius="15" Padding="22,20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                <GradientStop Color="#1a0e08" Offset="0"/>
                                <GradientStop Color="#1a0808" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Spacing="14">
                            <Border Width="42" Height="42" CornerRadius="12" HorizontalAlignment="Left">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#f9731635" Offset="0"/>
                                        <GradientStop Color="#ef444425" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="⏰" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding CitasPendientesConfirmar}"
                                       FontSize="46" FontWeight="Bold" Foreground="#f97316"/>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Sin confirmar"
                                           FontSize="13" Foreground="#94a3b8" FontWeight="Medium"/>
                                <TextBlock Text="próximos 7 días"
                                           FontSize="11" Foreground="#334155"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- ── Ingresos semana (opcional) ── -->
                <Border CornerRadius="16" Padding="1" MinWidth="190"
                        IsVisible="{Binding MostrarEconomia}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#fbbf24" Offset="0"/>
                            <GradientStop Color="#f59e0b" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border CornerRadius="15" Padding="22,20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                <GradientStop Color="#1a1408" Offset="0"/>
                                <GradientStop Color="#1a1208" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Spacing="14">
                            <Border Width="42" Height="42" CornerRadius="12" HorizontalAlignment="Left">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#fbbf2435" Offset="0"/>
                                        <GradientStop Color="#f59e0b25" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="💰" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding IngresosSemana, StringFormat='{}{0:N0}'}"
                                           FontSize="42" FontWeight="Bold" Foreground="#fbbf24"/>
                                <TextBlock Text="€" FontSize="22" FontWeight="Bold"
                                           Foreground="#fbbf24" VerticalAlignment="Bottom"
                                           Margin="2,0,0,6"/>
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Esta semana"
                                           FontSize="13" Foreground="#94a3b8" FontWeight="Medium"/>
                                <TextBlock Text="ingresos totales"
                                           FontSize="11" Foreground="#334155"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

            </StackPanel>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- CONTENIDO PRINCIPAL: CITAS + ALERTAS               -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Grid ColumnDefinitions="*,Auto" MinHeight="340">

                <!-- ── Panel Citas de hoy ── -->
                <Border Grid.Column="0" Margin="0,0,16,0"
                        CornerRadius="16" Padding="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1e293b" Offset="0"/>
                            <GradientStop Color="#0f172a" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border CornerRadius="15" Padding="24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#080d1a" Offset="0"/>
                                <GradientStop Color="#060a14" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <DockPanel>

                            <!-- Cabecera -->
                            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14">
                                    <Border Width="38" Height="38" CornerRadius="10">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#a855f730" Offset="0"/>
                                                <GradientStop Color="#6366f120" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="📅" FontSize="17"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Citas de hoy"
                                                   FontSize="16" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text="{Binding FechaHoy}"
                                                   FontSize="11" Foreground="#334155" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Badge con el número de citas -->
                                <Border Grid.Column="1" CornerRadius="20" Padding="1"
                                        VerticalAlignment="Center">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#a855f7" Offset="0"/>
                                            <GradientStop Color="#6366f1" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border CornerRadius="19" Padding="14,5">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#1a0f2e" Offset="0"/>
                                                <GradientStop Color="#0f1228" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="{Binding CitasHoyCount}"
                                                       FontSize="13" FontWeight="Bold" Foreground="#a855f7"/>
                                            <TextBlock Text="citas"
                                                       FontSize="12" Foreground="#4c1d95"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Border>
                            </Grid>

                            <!-- Separador degradado -->
                            <Border DockPanel.Dock="Top" Height="1" Margin="0,14,0,20">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#a855f740" Offset="0"/>
                                        <GradientStop Color="#6366f110" Offset="0.6"/>
                                        <GradientStop Color="#00000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- Estado vacío -->
                            <StackPanel DockPanel.Dock="Top"
                                        IsVisible="{Binding !CitasHoy.Count}"
                                        HorizontalAlignment="Center"
                                        Margin="0,48,0,0" Spacing="12">
                                <TextBlock Text="🗓️" FontSize="52"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Sin citas para hoy"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="#334155" HorizontalAlignment="Center"/>
                                <TextBlock Text="¡Día libre!"
                                           FontSize="12" Foreground="#1e293b"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Lista de citas con layout de timeline -->
                            <ScrollViewer IsVisible="{Binding CitasHoy.Count}"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding CitasHoy}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:Cita">
                                            <Grid ColumnDefinitions="70,16,*" Margin="0,0,0,14">

                                                <!-- Hora + duración -->
                                                <StackPanel Grid.Column="0"
                                                            VerticalAlignment="Top"
                                                            HorizontalAlignment="Right"
                                                            Margin="0,10,0,0" Spacing="3">
                                                    <TextBlock Text="{Binding HoraInicio, StringFormat='{}{0:hh\\:mm}'}"
                                                               FontSize="15" FontWeight="Bold"
                                                               Foreground="#a855f7"
                                                               HorizontalAlignment="Right"/>
                                                    <TextBlock Text="{Binding DuracionMinutos, StringFormat='{}{0}m'}"
                                                               FontSize="11" Foreground="#334155"
                                                               HorizontalAlignment="Right"/>
                                                </StackPanel>

                                                <!-- Conector de timeline (punto + línea) -->
                                                <StackPanel Grid.Column="1"
                                                            HorizontalAlignment="Center" Spacing="0">
                                                    <Border Width="10" Height="10" CornerRadius="5"
                                                            Margin="0,12,0,0">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#a855f7" Offset="0"/>
                                                                <GradientStop Color="#6366f1" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <Border Width="1" MinHeight="30" HorizontalAlignment="Center">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#a855f730" Offset="0"/>
                                                                <GradientStop Color="#00000000" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Tarjeta de cita -->
                                                <Border Grid.Column="2"
                                                        Background="#0f172a"
                                                        BorderBrush="#1e293b"
                                                        BorderThickness="1"
                                                        CornerRadius="12" Padding="16,12"
                                                        Margin="0,6,0,0">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <StackPanel Grid.Column="0" Spacing="5">
                                                            <TextBlock Text="{Binding Cliente.NombreCompleto}"
                                                                       FontSize="14" FontWeight="SemiBold"
                                                                       Foreground="#e2e8f0"/>
                                                            <TextBlock Text="{Binding Descripcion}"
                                                                       FontSize="12" Foreground="#475569"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>

                                                        <!-- Indicador de estado -->
                                                        <Border Grid.Column="1"
                                                                Width="8" Height="8" CornerRadius="4"
                                                                VerticalAlignment="Center" Margin="12,0,0,0">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#10b981" Offset="0"/>
                                                                    <GradientStop Color="#06b6d4" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                        </DockPanel>
                    </Border>
                </Border>

                <!-- ── Panel Alertas / Pendientes ── -->
                <Border Grid.Column="1" Width="310"
                        IsVisible="{Binding MostrarAlertas}"
                        CornerRadius="16" Padding="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1e293b" Offset="0"/>
                            <GradientStop Color="#0f172a" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border CornerRadius="15" Padding="24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#080d1a" Offset="0"/>
                                <GradientStop Color="#060a14" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <DockPanel>

                            <!-- Cabecera -->
                            <StackPanel DockPanel.Dock="Top"
                                        Orientation="Horizontal" Spacing="14"
                                        Margin="0,0,0,6">
                                <Border Width="38" Height="38" CornerRadius="10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#f9731630" Offset="0"/>
                                            <GradientStop Color="#ef444420" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="⚡" FontSize="17"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Pendientes"
                                               FontSize="16" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="requieren atención"
                                               FontSize="11" Foreground="#334155" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Separador degradado -->
                            <Border DockPanel.Dock="Top" Height="1" Margin="0,14,0,20">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#f9731640" Offset="0"/>
                                        <GradientStop Color="#ef444410" Offset="0.6"/>
                                        <GradientStop Color="#00000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- Estado vacío -->
                            <StackPanel DockPanel.Dock="Top"
                                        IsVisible="{Binding !Alertas.Count}"
                                        HorizontalAlignment="Center"
                                        Margin="0,42,0,0" Spacing="12">
                                <TextBlock Text="✨" FontSize="48"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Todo en orden"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="#334155"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="No hay pendientes"
                                           FontSize="12" Foreground="#1e293b"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Lista de alertas -->
                            <ScrollViewer IsVisible="{Binding Alertas.Count}"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Alertas}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="12" Padding="1" Margin="0,0,0,10">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#f9731655" Offset="0"/>
                                                        <GradientStop Color="#ef444435" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Border CornerRadius="11" Padding="14,12">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#150a08" Offset="0"/>
                                                            <GradientStop Color="#120808" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding}"
                                                               TextWrapping="Wrap"
                                                               FontSize="13" Foreground="#cbd5e1"
                                                               LineHeight="20"/>
                                                </Border>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                        </DockPanel>
                    </Border>
                </Border>

            </Grid>

        </StackPanel>
    </ScrollViewer>

</UserControl>

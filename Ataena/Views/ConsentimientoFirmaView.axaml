<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ataena.ViewModels"
             x:Class="Ataena.Views.ConsentimientoFirmaView"
             x:DataType="vm:ConsentimientoFirmaViewModel">

    <!-- Modal overlay -->
    <Border IsVisible="{Binding EsVisible, FallbackValue=False}"
            Background="#80000000"
            ZIndex="1000">
        
        <Border Background="#1e1e2e"
                CornerRadius="18"
                Padding="32"
                MinWidth="520"
                MaxWidth="860"
                MaxHeight="820"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BoxShadow="0 0 30 5 #a855f7, 0 0 50 8 #f97316">
            
            <Grid RowDefinitions="Auto,*,Auto,Auto">
                
                <!-- Header -->
                <Border Grid.Row="0"
                        Background="#2a2a3e"
                        Padding="24,20"
                        CornerRadius="18,18,0,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding TituloModal}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Content="✕"
                                FontSize="16"
                                Width="36"
                                Height="36"
                                Background="Transparent"
                                Foreground="#9ca3af"
                                BorderThickness="0"
                                CornerRadius="18"
                                Command="{Binding CancelarFirmaCommand}"/>
                    </Grid>
                </Border>

                <!-- Aviso de datos del tutor faltantes (para menores) -->
                <Border Grid.Row="1"
                        IsVisible="{Binding FaltanDatosTutor}"
                        Background="#7f1d1d"
                        BorderBrush="#ef4444"
                        BorderThickness="2"
                        CornerRadius="12"
                        Padding="24"
                        Margin="24,24,24,0"
                        VerticalAlignment="Top">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="⚠️"
                                       FontSize="28"
                                       VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="FALTAN DATOS DEL TUTOR"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#fca5a5"/>
                                <TextBlock Text="No se puede firmar consentimiento de menor sin datos del tutor"
                                           FontSize="13"
                                           Opacity="0.9"
                                           Foreground="White"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Height="1" Background="#ef4444" Opacity="0.3"/>
                        <TextBlock TextWrapping="Wrap"
                                   FontSize="13"
                                   Foreground="#fecaca"
                                   LineHeight="20">
                            <Run Text="Para firmar el consentimiento de un menor de edad, primero debes rellenar los datos del tutor o representante legal en la ficha del cliente:"/>
                        </TextBlock>
                        <StackPanel Spacing="4" Margin="12,0,0,0">
                            <TextBlock Text="• Nombre del tutor" FontSize="12" Foreground="#fecaca"/>
                            <TextBlock Text="• Apellidos del tutor" FontSize="12" Foreground="#fecaca"/>
                            <TextBlock Text="• DNI del tutor" FontSize="12" Foreground="#fecaca"/>
                            <TextBlock Text="• Teléfono del tutor" FontSize="12" Foreground="#fecaca"/>
                        </StackPanel>
                        <Border Height="1" Background="#ef4444" Opacity="0.3" Margin="0,4,0,0"/>
                        <TextBlock Text="👉 Cierra esta ventanita, edita el cliente y rellena los datos del tutor."
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>

                <!-- Contenido scrollable (oculto si faltan datos del tutor) -->
                <ScrollViewer Grid.Row="1"
                              IsVisible="{Binding !FaltanDatosTutor}"
                              Padding="28,24,40,24"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="20">
                        
                        <!-- Texto del consentimiento -->
                        <Border Background="#2a2a3e"
                                CornerRadius="12"
                                Padding="20">
                            <TextBlock Text="{Binding TextoConsentimiento}"
                                       TextWrapping="Wrap"
                                       LineHeight="24"
                                       LineSpacing="4"
                                       FontSize="13"/>
                        </Border>

                        <!-- Separador -->
                        <Border Height="1"
                                Background="#3a3a4e"
                                Margin="0,10"/>

                        <!-- Sección de firma móvil -->
                        <StackPanel Spacing="15">
                            <TextBlock Text="📱 FIRMA EN MÓVIL:"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0,0,0,5"/>
                            
                            <!-- QR Code -->
                            <Border Background="White"
                                    CornerRadius="12"
                                    Padding="20"
                                    HorizontalAlignment="Center">
                                <Image Source="{Binding QrCodeImage}"
                                       Width="250"
                                       Height="250"
                                       Stretch="Uniform"/>
                            </Border>

                            <!-- URL -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="O abre esta URL en tu móvil:"
                                           FontSize="12"
                                           Opacity="0.7"/>
                                <Border Background="#2a2a3e"
                                        CornerRadius="8"
                                        Padding="12">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding UrlFirma}"
                                                   TextWrapping="Wrap"
                                                   FontSize="11"
                                                   FontFamily="Consolas"
                                                   Opacity="0.9"/>
                                        <Button Grid.Column="1"
                                                Content="📋"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding CopiarUrlCommand}"
                                                Margin="10,0,0,0"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- Estado de conexión -->
                            <Border Background="#2a2a3e"
                                    CornerRadius="8"
                                    Padding="12">
                                <TextBlock Text="{Binding EstadoConexion}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                            </Border>

                            <TextBlock Text="{Binding TituloFaseFirma}"
                                       FontSize="12"
                                       Opacity="0.85"
                                       TextWrapping="Wrap"
                                       Margin="4,6,4,4"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Preview de firma (fila fija: no queda detrás del footer ni al final del scroll) -->
                <Border Grid.Row="2"
                        IsVisible="{Binding FirmaRecibida}"
                        Background="#1a4d2e"
                        CornerRadius="12"
                        Padding="16,12"
                        Margin="24,0,24,8"
                        BorderBrush="#10b981"
                        BorderThickness="2"
                        MaxHeight="280">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="10">
                            <TextBlock Text="✅ Firma(s) recibida(s)"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#10b981"
                                       TextWrapping="Wrap"/>
                            <StackPanel IsVisible="{Binding EsConsentimientoMenor}" Spacing="8">
                                <TextBlock Text="REPRESENTANTE LEGAL"
                                           FontWeight="Heavy"
                                           Foreground="#a7f3d0"
                                           TextWrapping="Wrap"/>
                                <Border Background="White"
                                        CornerRadius="8"
                                        Padding="8"
                                        HorizontalAlignment="Stretch">
                                    <Image Source="{Binding VistaPreviaRepresentanteDataUrl}"
                                           MaxHeight="100"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="MENOR"
                                           FontWeight="Heavy"
                                           Foreground="#a7f3d0"
                                           TextWrapping="Wrap"/>
                                <Border Background="White"
                                        CornerRadius="8"
                                        Padding="8"
                                        HorizontalAlignment="Stretch">
                                    <Image Source="{Binding VistaPreviaMenorDataUrl}"
                                           MaxHeight="100"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                            <StackPanel IsVisible="{Binding !EsConsentimientoMenor}">
                                <Border Background="White"
                                        CornerRadius="8"
                                        Padding="8"
                                        HorizontalAlignment="Stretch">
                                    <Image Source="{Binding VistaPreviaRepresentanteDataUrl}"
                                           MaxHeight="120"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Footer con botones -->
                <Border Grid.Row="3"
                        Background="#2a2a3e"
                        Padding="20,16"
                        CornerRadius="0,0,18,18">
                    <StackPanel Orientation="Horizontal"
                                Spacing="12"
                                HorizontalAlignment="Right">
                        <!-- Botones antes de generar PDF -->
                        <Button Classes="btn-secondary"
                                Command="{Binding CancelarFirmaCommand}"
                                IsEnabled="{Binding !EstaProcesando}"
                                IsVisible="{Binding !PdfGenerado}"
                                MinWidth="130"
                                MinHeight="46"
                                Padding="16,10"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Content="Cancelar"/>
                        <Button Classes="btn-primary"
                                Command="{Binding ConfirmarFirmaCommand}"
                                IsEnabled="{Binding FirmaRecibida}"
                                IsVisible="{Binding !PdfGenerado}"
                                MinWidth="160"
                                MinHeight="46"
                                Padding="16,10"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center">
                            <TextBlock Text="Generar PDF"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Border>
</UserControl>


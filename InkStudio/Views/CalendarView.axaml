<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InkStudio.ViewModels"
             xmlns:models="using:InkStudio.Models"
             xmlns:si="clr-namespace:SatialInterfaces.Controls.Calendar;assembly=CalendarControl"
             x:Class="InkStudio.Views.CalendarView"
             x:DataType="vm:CalendarViewModel">

    <UserControl.Styles>
        <!-- Estilo para AppointmentControl con efecto hover -->
        <Style Selector="si|AppointmentControl">
            <Setter Property="Opacity" Value="0.85"/>
        </Style>
        <Style Selector="si|AppointmentControl:pointerover">
            <Setter Property="Opacity" Value="1.0"/>
            <Setter Property="RenderTransform">
                <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="10">
        <!-- Controles de navegación -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,10">
            <Button Grid.Column="0" 
                    Content="◀ Semana Anterior" 
                    Command="{Binding SemanaAnteriorCommand}"
                    HorizontalAlignment="Left"/>
            
            <StackPanel Grid.Column="1" 
                       Orientation="Horizontal" 
                       HorizontalAlignment="Center"
                       Spacing="10">
                <TextBlock Text="{Binding SemanaActualTexto}"
                          FontSize="16"
                          FontWeight="Bold"
                          VerticalAlignment="Center"/>
                <Button Content="Hoy" 
                       Command="{Binding IrASemanaActualCommand}"
                       Margin="10,0,0,0"/>
            </StackPanel>
            
            <Button Grid.Column="2" 
                    Content="Semana Siguiente ▶" 
                    Command="{Binding SemanaSiguienteCommand}"
                    HorizontalAlignment="Right"/>
        </Grid>

        <!-- CalendarControl con ItemTemplate para mostrar las citas -->
        <Grid Grid.Row="1">
            <si:CalendarControl x:Name="CalendarControl"
                               Items="{Binding Citas}">
                <si:CalendarControl.ItemTemplate>
                    <DataTemplate x:DataType="models:Cita">
                        <si:AppointmentControl Begin="{Binding FechaHoraInicio}" 
                                              End="{Binding FechaHoraFin}" 
                                              Text="{Binding Descripcion, TargetNullValue='Sin descripción'}" />
                    </DataTemplate>
                </si:CalendarControl.ItemTemplate>
            </si:CalendarControl>
        </Grid>
    </Grid>

</UserControl>

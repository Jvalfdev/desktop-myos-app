<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:InkStudio.ViewModels"
        xmlns:views="using:InkStudio.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="InkStudio.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="InkStudio CRM"
        Width="1200"
        Height="700"
        MinWidth="900"
        MinHeight="600"
        Background="#12121a">

    <Window.Styles>
        <!-- Estilo para botones de navegación -->
        <Style Selector="Button.nav-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a0a0a0"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="8,2"/>
        </Style>
        <Style Selector="Button.nav-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2a2a3e"/>
        </Style>
        <Style Selector="Button.nav-btn.active">
            <Setter Property="Background" Value="#2a2a3e"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.nav-btn.active /template/ ContentPresenter">
            <Setter Property="Background" Value="#2a2a3e"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="220,*">
        
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUMNA 0: BARRA DE NAVEGACIÓN LATERAL                          -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="#16161e">
            <DockPanel>
                
                <!-- Logo / Título -->
                <Border DockPanel.Dock="Top" Padding="20" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="🖋️ InkStudio" 
                                   FontSize="22" 
                                   FontWeight="Bold"/>
                        <TextBlock Text="CRM" 
                                   FontSize="12" 
                                   Opacity="0.5"
                                   Margin="28,0,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Menú de navegación -->
                <StackPanel DockPanel.Dock="Top" Margin="0,10,0,0">
                    
                    <Button Classes="nav-btn active" Command="{Binding IrADashboardCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="🏠" FontSize="18"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Classes="nav-btn" Command="{Binding IrAClientesCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="👥" FontSize="18"/>
                            <TextBlock Text="Clientes" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Classes="nav-btn" Command="{Binding IrAAgendaCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="📅" FontSize="18"/>
                            <TextBlock Text="Agenda" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Classes="nav-btn" Command="{Binding IrATrabajosCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="💼" FontSize="18"/>
                            <TextBlock Text="Trabajos" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                </StackPanel>
                
                <!-- Separador -->
                <Border DockPanel.Dock="Top" 
                        Height="1" 
                        Background="#2a2a3e" 
                        Margin="20,20"/>
                
                <!-- Configuración (abajo) -->
                <Button Classes="nav-btn" 
                        DockPanel.Dock="Bottom" 
                        Margin="8,0,8,20"
                        Command="{Binding IrAConfiguracionCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="⚙️" FontSize="18"/>
                        <TextBlock Text="Configuración" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <!-- Espaciador -->
                <Border/>
                
            </DockPanel>
        </Border>
        
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUMNA 1: CONTENIDO PRINCIPAL                                  -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="1" Background="#12121a">
            <!-- Por ahora mostramos directamente el Dashboard -->
            <views:DashboardView DataContext="{Binding DashboardVM}"/>
        </Border>
        
    </Grid>

</Window>
